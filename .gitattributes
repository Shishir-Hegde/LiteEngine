# Normalize all text files to LF line endings
* text=auto eol=lf

# Explicitly mark C++ source files as text
*.cpp text eol=lf
*.h   text eol=lf
*.c   text eol=lf
*.lua text eol=lf

# Explicitly mark binary files so git never touches them
*.png binary
*.jpg binary
*.lib binary
*.dll binary
*.exe binary

# Ensure Dear ImGui source files keep LF endings to avoid corrupting long embedded literals
# Treat all files under vendor/imgui as text and normalize to LF on checkout.
/LiteEngine/vendor/imgui/** text eol=lf

# Also ensure any imgui headers in other locations are normalized to LF
**/vendor/imgui/** text eol=lf

# Prevent automatic CRLF conversion for generated/compressed font data files specifically
/LiteEngine/vendor/imgui/imgui_draw.cpp text eol=lf
/LiteEngine/vendor/imgui/imgui.cpp text eol=lf
/LiteEngine/vendor/imgui/imgui.h text eol=lf
