# Normalize all text files to LF line endings
* text=auto eol=lf

# Explicitly mark C++ source files as text
*.cpp text eol=lf
*.h   text eol=lf
*.c   text eol=lf
*.lua text eol=lf

# Explicitly mark binary files so git never touches them
*.png binary
*.jpg binary
*.lib binary
*.dll binary
*.exe binary